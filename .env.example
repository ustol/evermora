# Clerk (https://dashboard.clerk.com -> your app -> API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Reserved for future server-side use (Clerk webhooks). Not read by the
# client app today — never expose a secret key with a VITE_ prefix.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (https://supabase.com/dashboard -> your project -> Project Settings -> API Keys)
# Use the "publishable" key (sb_publishable_...), not the secret key.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public base URL of this app (used for building shareable memorial links)
VITE_APP_URL=http://localhost:5173

# Paystack (https://dashboard.paystack.com -> Settings -> API Keys & Webhooks)
# Use the PUBLIC key here — never expose the secret key with a VITE_ prefix.
# The secret key belongs only in the Supabase Edge Function secrets
# (PAYSTACK_SECRET_KEY), set via the Supabase dashboard or `supabase secrets set`.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
